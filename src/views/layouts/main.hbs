<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Yo Juego - MVP</title>
  <link rel="stylesheet" href="/css/style.css">
  <!-- Bootstrap 5 CDN para maquetar rápido sin renegar con CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

  <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container">
    <a class="navbar-brand fw-bold text-success" href="/">🏟️ Yo Juego</a>
    
    <div class="ms-auto">
      {{#if isAuthenticated}}
        <span class="text-light me-3 small">¡Hola! ⚽</span>
        <a href="/web/logout" class="btn btn-outline-danger btn-sm">Cerrar Sesión</a>
      {{else}}
        <a href="/web/login" class="btn btn-success btn-sm me-2">Ir al Login</a>
        <a href="/web/register" class="btn btn-outline-secondary btn-sm">Registrarse</a>
      {{/if}}
    </div>
  </div>
</nav>

  <!-- Contenido Dinámico -->
  <main class="container">
    {{{body}}}
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>