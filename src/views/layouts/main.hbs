<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Yo Juego</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-dark-principal text-light-suave d-flex flex-column min-vh-100">

  <nav class="navbar navbar-expand-lg navbar-dark bg-dark-card border-bottom border-secondary border-opacity-10 shadow-sm">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center fw-bold logo-texto-gradient" href="/">
        <img src="/images/logo.jpg" alt="Logo Yo Juego" width="42" height="42" class="d-inline-block align-top me-2 rounded logo-img-blend my-auto">
        YoJuego
      </a>
      
      <div class="ms-auto d-flex align-items-center">
        {{#if isAuthenticated}}
          <span class="text-light-suave me-3 small">
            ¡Hola, <strong class="text-success-neon">{{#if user.nombre}}{{user.nombre}}{{else}}Crack{{/if}}</strong>!
          </span>
          <a href="/web/logout" class="btn btn-outline-orange btn-sm custom-btn">Cerrar Sesión</a>
        {{else}}
          <a href="/web/login" class="btn btn-success-neon btn-sm me-2 custom-btn">Ir al Login</a>
          <a href="/web/register" class="btn btn-outline-orange btn-sm custom-btn">Registrarse</a>
        {{/if}}
      </div>
    </div>
  </nav>

  <main class="container my-5 flex-grow-1">
    {{{body}}}
  </main>

  <footer class="bg-dark-card border-top border-secondary border-opacity-10 pt-5 pb-3 mt-auto">
    <div class="container">
      <div class="row g-4 text-start">
        
        <div class="col-12 col-md-6">
          <h5 class="fw-bold text-white mb-3 text-uppercase tracking-wide footer-brand-txt">YoJuego</h5>
          <p class="small text-white-50 lh-base mb-0" style="max-width: 450px;">
            La plataforma definitiva para la gestión y organización de partidos de fútbol amateur de la comunidad universitaria.
          </p>
        </div>

        <div class="col-12 col-md-6 text-md-end">
          <h6 class="text-white fw-bold text-uppercase tracking-wider small mb-3">Accesos</h6>
          <ul class="list-unstyled d-flex flex-row flex-wrap justify-content-md-end gap-4 small mb-0">
            <li><a href="/" class="text-white-50 text-decoration-none footer-link-hover">Inicio</a></li>
            {{#if isAuthenticated}}
              <li><a href="/web/logout" class="text-white-50 text-decoration-none footer-link-hover">Cerrar Sesión</a></li>
            {{else}}
              <li><a href="/web/login" class="text-white-50 text-decoration-none footer-link-hover">Iniciar Sesión</a></li>
              <li><a href="/web/register" class="text-white-50 text-decoration-none footer-link-hover">Registrarse</a></li>
            {{/if}}
          </ul>
        </div>

      </div>

      <hr class="border-secondary border-opacity-10 my-4">

      <div class="row align-items-center small text-white-50">
        <div class="col-12 col-md-6 text-center text-md-start mb-2 mb-md-0">
          <span>&copy; 2026 YoJuego. Todos los derechos reservados.</span>
        </div>
        <div class="col-12 col-md-6 text-center text-md-end">
          <span class="text-uppercase tracking-wider footer-version">Versión 1.2.0 • UNSAM</span>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>