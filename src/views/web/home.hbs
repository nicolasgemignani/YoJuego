<div class="container mt-5">
  
  <div class="text-center mb-5 pt-4">
    <h1 class="display-5 fw-bold text-success-neon text-uppercase tracking-wide mb-2">
      Próximos Partidos
    </h1>
    <p class="lead text-light-suave fs-6 text-white-50">
      Revisá la lista de encuentros disponibles, asegurá tu lugar en la cancha o sumate a la lista de espera.
    </p>
  </div>

  {{#if success}}
    <div class="alert custom-alert-minimal alert-dismissible fade show shadow-sm mb-4" role="alert">
      <div class="d-flex align-items-center">
        <!-- Un punto neón sutil en lugar de un icono o texto pesado -->
        <span class="alert-dot me-3"></span>
        <span class="small text-white-50">{{success}}</span>
      </div>
      <button type="button" class="btn-close btn-close-white custom-close-minimal" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  {{/if}}

  {{#if error}}
    <div class="alert alert-warning bg-warning bg-opacity-10 border-warning text-warning alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
      <strong>⚠️ Atención:</strong> {{error}}
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  {{/if}}

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {{#each partidos}}
      <div class="col">
        
        <div class="card h-100 bg-dark-card border-secondary border-opacity-10 shadow-lg rounded-3">
          
          <div class="card-header d-flex justify-content-between align-items-center bg-transparent border-0 pt-3">
            <span class="badge bg-secondary bg-opacity-20 text-white-50 border border-secondary border-opacity-10 px-2 py-1.5">
              Fútbol {{this.tipoCancha}}
            </span> 
            
            {{#if this.estaCompleto}}
              {{#if this.listaEsperaLlena}}
                <span class="badge bg-orange-deportivo text-white px-2 py-1.5 shadow-sm fw-bold">
                  Completo
                </span>
              {{else}}
                <span class="badge bg-warning bg-opacity-10 text-warning-deportivo border border-warning border-opacity-30 px-2 py-1.5 fw-bold">
                  Lista de Espera
                </span>
              {{/if}}
            {{else}}
              <span class="badge bg-success bg-opacity-10 text-success-neon border border-success border-opacity-30 px-2 py-1.5 fw-bold">
                Cupos Disponibles
              </span>
            {{/if}}
          </div>

          <div class="card-body">
            <h5 class="card-title fw-bold text-white mb-3">📍 {{this.lugar}}</h5>
            <p class="card-text mb-1 text-light-suave"><strong>Fecha:</strong> {{this.fechaFormateada}}</p>
            <p class="card-text mb-3 text-light-suave"><strong>Hora:</strong> {{this.hora}} hs</p>

            <div class="mb-3 mt-2">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small text-light-suave">Jugadores confirmados</span>
                <span class="small fw-bold text-success-neon">{{this.contadorTitulares}}</span>
              </div>
              <div class="progress bg-dark-principal" style="height: 6px;">
                <div class="progress-bar progress-bar-gradient" role="progressbar" style="width: {{this.porcentajeTitulares}}%;"></div>
              </div>
            </div>

            {{#if this.estaCompleto}}
              <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <span class="small text-light-suave">Lista de espera</span>
                  <span class="small fw-bold text-warning-deportivo">{{this.contadorSuplentesStr}}</span>
                </div>
                <div class="progress bg-dark-principal" style="height: 6px;">
                  <div class="progress-bar progress-bar-suplentes" role="progressbar" style="width: {{this.porcentajeSuplentes}}%;"></div>
                </div>
              </div>
            {{else}}
              <div class="mb-4 d-flex align-items-center custom-motivation-block">
                <span class="small text-success-neon border border-success border-opacity-10 bg-success bg-opacity-5 rounded-2 px-2 py-1.5 w-100 text-center text-uppercase tracking-wider">
                  Quedan lugares • Asegurá tu lugar hoy
                </span>
              </div>
            {{/if}}
            
            <a href="/partidos/{{this._id}}" class="btn btn-link btn-sm text-success-neon p-0 fw-bold text-decoration-none card-link-hover">Ver lista de anotados →</a>
          </div>

          <div class="card-footer bg-transparent border-0 pb-3">
            {{#if ../isAuthenticated}}
              
              {{#if this.yaTermino}}
                {{#if this.puedeValorar}}
                  <a href="/web/votos/{{this._id}}/votar" class="btn btn-success-neon w-100 custom-btn btn-sm">Valorar Partido</a>
                {{else}}
                  <button class="btn btn-outline-secondary w-100 btn-sm custom-btn" disabled>
                    {{#if this.esTitular}}Jugaste este partido{{else}}Partido finalizado{{/if}}
                  </button>
                {{/if}}

              {{else}}
                {{#if this.yaInscripto}}
                  <form action="/partidos/{{this._id}}/bajarse" method="POST">
                    <button type="submit" class="btn btn-outline-orange w-100 custom-btn btn-sm">
                      {{#if this.esSuplente}}Salir de Lista de Espera{{else}}Salir del Partido{{/if}}
                    </button>
                  </form>
                {{else}}
                  {{#if this.puedeAnotarse}}
                    {{#if this.estaCompleto}}
                      {{#if this.listaEsperaLlena}}
                        <button class="btn btn-outline-secondary w-100 btn-sm custom-btn" disabled>Partido y Lista Llenos</button>
                      {{else}}
                        <form action="/partidos/{{this._id}}/unirse" method="POST">
                          <button type="submit" class="btn btn-outline-warning text-warning-deportivo w-100 custom-btn btn-sm">Anotarse como Suplente</button>
                        </form>
                      {{/if}}
                    {{else}}
                      <form action="/partidos/{{this._id}}/unirse" method="POST">
                        <button type="submit" class="btn btn-success-neon w-100 custom-btn btn-sm">Unirme al Partido</button>
                      </form>
                    {{/if}}
                  {{else}}
                    <button class="btn btn-outline-secondary w-100 btn-sm custom-btn" disabled>Cerrado</button>
                  {{/if}}
                {{/if}}
              {{/if}}

            {{else}}
              {{#if this.estaCompleto}}
                <a href="/web/login" class="btn btn-outline-secondary w-100 btn-sm custom-btn">Lleno • Iniciá sesión</a>
              {{else}}
                <a href="/web/login" class="btn btn-outline-success text-success-neon w-100 btn-sm custom-btn">Iniciá sesión para unirte</a>
              {{/if}}
            {{/if}}
          </div>
          
        </div> 
      </div> 
    {{else}}
      <div class="col-12 text-center my-5">
        <div class="card bg-dark-card border-secondary border-opacity-10 p-5 rounded-3 shadow-lg">
          <p class="fs-4 text-light-suave mb-0">No hay partidos programados en la cartelera actualmente.</p>
        </div>
      </div>
    {{/each}}
  </div>

</div>