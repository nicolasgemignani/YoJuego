<div class="row justify-content-center mt-5">
  <div class="col-md-5"> <div class="card bg-dark-card border-secondary border-opacity-10 shadow-lg rounded-3">
      <div class="card-body p-5">
        
        <h2 class="card-title text-center mb-4 fw-bold text-success-neon">Iniciar Sesión</h2>

        {{#if registradoExitosamente}}
          <div class="alert alert-success bg-success bg-opacity-10 border-success text-success border-0 shadow-sm mb-4" role="alert">
            🎉 ¡Registro exitoso! Ya podés iniciar sesión.
          </div>
        {{/if}}

        {{#if error}}
          <div class="alert alert-warning bg-warning bg-opacity-10 border-warning text-warning border-0 shadow-sm mb-4" role="alert">
            ⚠️ {{error}}
          </div>
        {{/if}}

        <form action="/web/login" method="POST">
          {{#if redirect}}
            <input type="hidden" name="redirect" value="{{redirect}}">
          {{/if}}

          <div class="mb-3">
            <label class="form-label text-light-suave small fw-medium">Correo Electrónico</label>
            <input type="email" name="email" class="form-control login-input" value="{{valores.email}}" required placeholder="ejemplo@yojuego.com">
          </div>

          <div class="mb-4">
            <label class="form-label text-light-suave small fw-medium">Contraseña</label>
            <input type="password" name="password" class="form-control login-input" required placeholder="Tu contraseña">
          </div>

          <button type="submit" class="btn btn-success-neon w-100 btn-lg mt-2 custom-btn">
            Ingresar a YoJuego
          </button>
          
          <div class="text-center mt-4">
            <a href="/web/register" class="link-orange small text-decoration-none">¿No tenés cuenta? Registrate acá →</a>
          </div>
        </form>
      </div>
    </div>

  </div>
</div>